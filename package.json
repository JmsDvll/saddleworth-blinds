{
  "name": "saddleworth-blinds",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "optimize-images": "node optimize-images.js",
    "agent:status": "node scripts/agent-status.js",
    "prepare": "husky",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "test:a11y": "axe http://localhost:4173 --load-delay 2000",
    "test:perf": "lighthouse http://localhost:4173 --quiet --no-enable-error-reporting --chrome-flags=--headless --only-categories=performance,accessibility,best-practices,seo --output=json --output-path=./lighthouse-report.json",
    "check:axe": "axe http://localhost:4173",
    "check:lighthouse": "lighthouse http://localhost:4173 --quiet --chrome-flags=--headless --only-categories=performance,accessibility,best-practices,seo --output=json --output-path=./lighthouse-report.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "framer-motion": "^10.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.48.2",
    "react-intersection-observer": "^9.5.3",
    "react-router-dom": "^6.21.1",
    "yup": "^1.3.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.23",
    "husky": "^9.1.7",
    "@playwright/test": "^1.48.2",
    "@axe-core/cli": "^4.10.1",
    "lighthouse": "^11.7.0",
    "postcss": "^8.4.32",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.4.0",
    "vite": "^7.1.9"
  }
}
